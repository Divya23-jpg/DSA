//colum wise max find
int  colSum(int mat[][100],int n){
    int sum=INT_MIN;
    for(int i=0;i<n;i++){
        int csum=0;
        for(int j=0;j<n;j++){
            csum +=mat[j][i];
          
            
        }
        sum=max(sum,csum);
        
      
    }
    return  sum;

}



